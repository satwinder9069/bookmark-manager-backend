# MongoDB Connection String (e.g., from MongoDB Atlas)
MONGO_URI=your_mongodb_connection_string

# Authentication Secrets
JWT_SECRET=your_super_secret_jwt_key

# Client URL for CORS/Redirects
FRONTEND_URL=http://localhost:5173

# Email Service Configuration (SendGrid or SMTP)
SENDGRID_API_KEY=your_sendgrid_api_key

# OR if using SMTP authentication:
EMAIL_SENDER=your_verified_sender_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# Server Configuration
NODE_ENV=development
PORT=5000